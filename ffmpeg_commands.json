{
    "Tăng âm lượng": {
        "cmd": "-filter:a \"volume=30dB\" -c:v copy",
        "ext": ".mp4"
    },
    "Nén ảnh": {
        "cmd": "-q:v 5",
        "ext": ".jpg"
    },
    "Nén video": {
        "cmd": "-c:v libx264 -preset slower -crf 20 -tune film -r 60 -vf \"scale=-2:1080,format=yuv420p\" -c:a aac -b:a 192k",
        "ext": ".mp4"
    }
}